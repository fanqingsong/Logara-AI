# --- LLM (GLM via OpenAI-compatible API) ---
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_API_KEY=your_glm_api_key_here
LLM_MODEL=glm-5.1

# --- Embedding (SiliconFlow) ---
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1/
EMBEDDING_API_KEY=your_siliconflow_api_key_here
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024

# --- Vector Database ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY= (optional for local)

# --- Server Configuration ---
PORT=8000
DEBUG=True

# --- Database ---
DATABASE_URL=sqlite:///./logara.db

# --- Redaction Settings ---
REDACT_ENABLED=true
REDACT_PATTERNS=jwt,aws_access_key,api_key,bearer,email,credit_card
REDACT_IPV4=false

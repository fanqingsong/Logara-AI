# AI Engine Environment Variables
# Copy to .env in the repository root and set values as needed.

# Qdrant vector database
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=logs

# Ollama local LLM — model must be pulled before use:
#   docker exec <ollama-container> ollama pull llama3
#   docker exec <ollama-container> ollama pull mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3          # alternatives: mistral, phi3, gemma2

# Sentence-transformer embedding model (must match the backend worker)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

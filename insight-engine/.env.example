# AI Engine Environment Variables
# Copy to .env in the repository root and set values as needed.

# Qdrant vector database
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=logs

# LLM (GLM via OpenAI-compatible API)
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_API_KEY=your_glm_api_key_here
LLM_MODEL=glm-5.1

# Embedding (SiliconFlow via OpenAI-compatible API)
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1/
EMBEDDING_API_KEY=your_siliconflow_api_key_here
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
